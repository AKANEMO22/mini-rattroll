        </mxCell>
        <mxCell id="12" value="RecommendationService\nRole: generate movie list\nInput: user_id, top_k, drift_state\nOutput: ranked recommendations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E293B;strokeColor=#22C55E;fontColor=#E2E8F0;" vertex="1" parent="1">
