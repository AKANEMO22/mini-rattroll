          <mxGeometry x="870" y="280" width="340" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="20" value="data/ml-25m/ratings.csv + movies.csv\nMovieLens 25M source\nUsed by DatasetService" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#94A3B8;fontColor=#E2E8F0;" vertex="1" parent="1">
          <mxGeometry x="870" y="375" width="340" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="21" value="api/services/dataset_service.py\nDataset info / search / user profile / history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#94A3B8;fontColor=#E2E8F0;" vertex="1" parent="1">
          <mxGeometry x="870" y="485" width="340" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="22" value="Algorithm Role Summary" style="swimlane;whiteSpace=wrap;html=1;fillColor=#1D4ED8;strokeColor=#93C5FD;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="1280" y="20" width="860" height="640" as="geometry"/>
        </mxCell>
        <mxCell id="23" value="1) Recommendation algorithm\nInput: user_id, top_k, baseline JSON, drift state\nProcess: cache check → seed random by user_id → pick top movies → apply drift penalty\nOutput: list of items {item_id, title, year, genres, score}\nRole: serve online recommendations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B1220;strokeColor=#22C55E;fontColor=#E2E8F0;" vertex="1" parent="1">
          <mxGeometry x="1310" y="80" width="380" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="24" value="2) Drift simulation\nInput: drift_type, severity from UI\nProcess: save to drift_state.json\nOutput: state consumed by recommendation & monitoring\nRole: inject synthetic drift for testing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B1220;strokeColor=#C084FC;fontColor=#E2E8F0;" vertex="1" parent="1">
          <mxGeometry x="1710" y="80" width="380" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="25" value="3) Drift detection\nInput: recent_scores, baseline_scores\nProcess: if recent_scores < 20 then auto-generate traffic → KS test\nOutput: {is_drift, p_value, drift_score}\nRole: decide whether model behavior diverged" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B1220;strokeColor=#F97316;fontColor=#E2E8F0;" vertex="1" parent="1">
          <mxGeometry x="1310" y="270" width="380" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="26" value="4) Evaluation\nInput: recommendation service, 20 random users\nProcess: run top_k=10, calculate precision/NDCG/recall, append history\nOutput: metrics JSON + chart data\nRole: offline quality monitoring" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B1220;strokeColor=#22C55E;fontColor=#E2E8F0;" vertex="1" parent="1">
          <mxGeometry x="1710" y="270" width="380" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="27" value="5) Dataset service\nInput: query, user_id, dataset path\nProcess: load movies.csv, scan ratings.csv by chunks, join movie titles\nOutput: dataset info, search results, user profile, global history\nRole: expose MovieLens data to UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B1220;strokeColor=#94A3B8;fontColor=#E2E8F0;" vertex="1" parent="1">
          <mxGeometry x="1310" y="470" width="780" height="135" as="geometry"/>
        </mxCell>

        <mxCell id="28" value="Open app / start services" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1E3A8A;strokeColor=#93C5FD;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="70" y="30" width="180" height="40" as="geometry"/>
        </mxCell>
