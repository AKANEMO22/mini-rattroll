        <mxCell id="17" value="data/top_movies_baseline.json\nBaseline rankings + genres + mean_rating\nUsed by RecommendationService" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#34D399;fontColor=#E2E8F0;" vertex="1" parent="1">
